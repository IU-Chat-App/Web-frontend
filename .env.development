# Local development: route API calls through the Vite proxy (avoids CORS).
# Your backend should listen on VITE_PROXY_TARGET and expose /admin/* routes.
VITE_API_URL=/api
VITE_PROXY_TARGET=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# Set VITE_API_DEBUG=true to log every admin/auth request in the console.
# VITE_API_DEBUG=true
